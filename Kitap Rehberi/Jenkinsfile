pipeline {
    agent any

    stages {
        stage('Checkout') {
            steps {
                git branch: 'main', url: 'https://github.com/eylemgokce/kitap-rehberi.git'
            }
        }

        stage('Build and Deploy') {
            steps {
                // Jenkins'e önce klasörün içine girmesini söylüyoruz
                dir('Kitap Rehberi') {
                    sh 'docker compose down'
                    sh 'docker compose up -d --build'
                }
            }
        }

        stage('Health Check') {
            steps {
                script {
                    sleep 15
                    sh 'curl -f http://localhost:5173 || echo "Frontend henuz hazir degil"'
                }
            }
        }
    }

    post {
        success {
            echo '🎉 Harika! Deploy basarili: Kitap Rehberi calisiyor.'
        }
        failure {
            echo '❌ Eyvah! Deploy basarisiz: loglari kontrol et.'
        }
    }
}